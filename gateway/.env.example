# Durar AI — Environment Variables
# Copy to .env and fill in what you need

# ─── Gateway ─────────────────────────────────────────────────────────────────
DURAR_AI_GATEWAY_TOKEN=change-me-to-a-long-random-token
DURAR_AI_PORT=3741
DURAR_AI_HOST=127.0.0.1

# ─── Ollama (local models — no key needed) ───────────────────────────────────
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ─── Cloud providers (set at least one if not using Ollama) ──────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
